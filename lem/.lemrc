;; -*- mode:lisp -*-
;;
;; Entry point. Each piece of config lives in init/*.lisp.

(use-package :lem-user)

(let ((init-dir (merge-pathnames "init/" (or *load-truename* *load-pathname*))))
  (dolist (module '("themes" "looks" "vars" "commands" "keybindings" "modes"))
    (load (merge-pathnames (concatenate 'string module ".lisp") init-dir))))
